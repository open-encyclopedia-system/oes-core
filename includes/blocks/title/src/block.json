{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "oes/title",
  "version": "0.1.0",
  "title": "Display Title",
  "category": "oes-schema",
  "description": "Display the OES display title which may differ from the WordPress title.",
  "supports": {
    "align": true,
    "alignWide": true,
    "anchor": true,
    "ariaLabel": true,
    "className": true,
    "customClassName": true,
    "html": true,
    "inserter": true,
    "lock": true,
    "multiple": true,
    "reusable": true,
    "renaming": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true,
      "fontFamily": true,
      "fontWeight": true,
      "fontStyle": true,
      "textTransform": true,
      "textDecoration": true,
      "letterSpacing": true,
      "writingMode": true
    },
    "color": {
      "background": true,
      "heading": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}